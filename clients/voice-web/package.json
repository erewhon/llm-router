{
  "name": "voice-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Bespoke handoff-aware front end for the LLM Router voice assistant (Moshi + Expert).",
  "scripts": {
    "copy-workers": "node scripts/copy-workers.mjs",
    "predev": "pnpm run copy-workers",
    "dev": "vite",
    "prebuild": "pnpm run copy-workers",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "prettier --check src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "opus-recorder": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
