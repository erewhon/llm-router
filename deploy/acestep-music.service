# systemd unit for ACE-Step 1.5 music generation server (acestep.cpp CUDA)
# Deploy to: hypatia
# Install: sudo cp acestep-music.service /etc/systemd/system/
#          sudo systemctl daemon-reload
#          sudo systemctl enable --now acestep-music

[Unit]
Description=ACE-Step 1.5 Music Generation Server (CUDA)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=erewhon
Group=erewhon
Environment=LD_LIBRARY_PATH=/opt/acestep-cuda:/usr/local/cuda/lib64

ExecStart=/opt/acestep-cuda/ace-server \
    --models /home/erewhon/models/acestep \
    --keep-loaded \
    --host 0.0.0.0 \
    --port 5403

Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
