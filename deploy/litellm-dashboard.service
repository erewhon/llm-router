# systemd unit for LLM Router dashboard with sandboxing
# Install: sudo cp litellm-dashboard.service /etc/systemd/system/litellm-dashboard.service
#          sudo systemctl daemon-reload
#          sudo systemctl enable --now litellm-dashboard

[Unit]
Description=LLM Router Dashboard
# Deliberately NO dependency on a proxy unit. This was Wants/After=
# litellm-proxy.service, which silently resurrected LiteLLM on every
# dashboard restart — and llm-router-go's Conflicts=litellm-proxy then
# knocked the Go router off :4010. The dashboard reaches the node agents
# and the Go router over HTTP; it needs neither proxy at startup.
After=network-online.target
Wants=network-online.target

[Service]
Type=simple

ExecStart=/home/erewhon/Projects/erewhon/llm-router/.venv/bin/python \
    -m llm_router.dashboard \
    --registry /home/erewhon/Projects/erewhon/llm-router/models.yaml \
    --litellm-url http://localhost:4010 \
    --litellm-key sk-litellm-master \
    --port 4011

Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# --- Sandboxing ---
DynamicUser=yes
ProtectSystem=strict
PrivateTmp=yes
ProtectHome=tmpfs
BindReadOnlyPaths=/home/erewhon/Projects/erewhon/llm-router/.venv
BindReadOnlyPaths=/home/erewhon/Projects/erewhon/llm-router/src
BindReadOnlyPaths=/home/erewhon/Projects/erewhon/llm-router/models.yaml
# uv-managed Python
BindReadOnlyPaths=-/home/erewhon/.local/share/uv/python
# Linuxbrew Python (euclid fallback)
BindReadOnlyPaths=-/home/linuxbrew

ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes

NoNewPrivileges=yes
CapabilityBoundingSet=
AmbientCapabilities=

SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources @mount
SystemCallArchitectures=native

RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes

PrivateDevices=yes
MemoryDenyWriteExecute=no
LockPersonality=yes
UMask=0077

[Install]
WantedBy=multi-user.target
