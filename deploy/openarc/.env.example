# Copy to .env (gitignored) and fill in. Do NOT commit the real key.
#
#   cp .env.example .env
#
# The API key currently lives baked in the running euclid container; the
# canonical home is `ho secret` — e.g.:
#   ho secret set llm-router/openarc-api-key   # store once
#   echo "OPENARC_API_KEY=$(ho secret get llm-router/openarc-api-key)" > .env

OPENARC_API_KEY=changeme

# Optional — override the comma-separated autoload list (no spaces).
# Default (when unset): qwen3-embedding-4b,qwen3-reranker-4b
#OPENARC_AUTOLOAD_MODEL=qwen3-embedding-4b,qwen3-reranker-4b
