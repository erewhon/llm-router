# Optional overrides for deploy/router-db/docker-compose.yaml.
# Copy to .env only if you need to change a default — none are required on euclid.
#
#   cp .env.example .env

# NetBird mesh IP the DB publishes on for the HA peer (delphi). Default matches
# euclid's wt0 address; change if euclid's NetBird IP ever changes.
#ROUTER_DB_MESH_IP=100.72.235.6

# Only needed to initialize a FRESH database (empty volume). euclid's
# llm-router-pgdata volume is already initialized, so this is unused there.
# To use it on a new host, also add `- POSTGRES_PASSWORD=${POSTGRES_PASSWORD}`
# to the compose `environment:` block.
#POSTGRES_PASSWORD=
